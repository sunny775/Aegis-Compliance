# ─────────────────────────────────────────────────────────────────────────────
# Server — packages/server  (loaded from packages/server/.env)
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude API key. Server-side only — never shipped to the client.
ANTHROPIC_API_KEY=

# Model routing: capability tier → concrete model name (ARCHITECTURE.md §8.1).
# Defaults are applied if these are omitted.
CLAUDE_MODEL_CHEAP=claude-haiku-4-5
CLAUDE_MODEL_REASONING=claude-sonnet-4-6

# HTTP port the API server listens on.
PORT=4000

# Allowed frontend origin for CORS (the web dev server).
CORS_ORIGIN=http://localhost:5173

# Mock login credentials (identification only — not real security).
AUTH_USERNAME=admin
AUTH_PASSWORD=compliance-demo

# Optional: override the directory holding the six source PDFs (defaults to repo-root/docs).
# DOCS_DIR=/absolute/path/to/docs

# ─────────────────────────────────────────────────────────────────────────────
# Web — packages/web  (loaded from packages/web/.env; must be VITE_-prefixed)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the backend API.
VITE_API_URL=http://localhost:4000
