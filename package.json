{
  "name": "compliance-document-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Compliance Document Analyzer (Queensland coal-mining procedures vs Recognised Standards)",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
